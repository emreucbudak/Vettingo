{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "AnalyticsService": {
        "ClusterId": "analyticsservice",
        "Match": {
          "Path": "/analytics/{**catch-all}"
        }
      },
      "AuthService": {
        "ClusterId": "authservice",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/auth"
          }
        ]
      },
      "EvaluationService": {
        "ClusterId": "evaluationservice",
        "Match": {
          "Path": "/evaluation/{**catch-all}"
        }
      },
      "NotificationService": {
        "ClusterId": "notificationservice",
        "Match": {
          "Path": "/notification/{**catch-all}"
        }
      },
      "ExamService": {
        "ClusterId": "examservice",
        "Match": {
          "Path": "/exam/{**catch-all}"
        }
      },
      "JobService": {
        "ClusterId": "jobservice",
        "Match": {
          "Path": "/job/{**catch-all}"
        }
      },
      "InterviewService": {
        "ClusterId": "interviewservice",
        "Match": {
          "Path": "/interview/{**catch-all}"
        }
      }


    },
    "Clusters": {
      "analyticsservice": {
        "Destinations": {
          "analyticsservice": {
            "Address": "https://localhost:5266/api/analytics"
          }
        }
      },
      "authservice": {
        "Destinations": {
          "authservice": {
            "Address": "http://localhost:5254/api/auth"
          }
        }
      },
      "evaluationservice": {
        "Destinations": {
          "evaluationservice": {
            "Address": "https://localhost:5083/api/evaluation"
          }
        }
      },
      "interviewservice": {
        "Destinations": {
          "interviewservice": {
            "Address": "https://localhost:5077/api/interview"
          }
        }
      },
      "jobservice": {
        "Destinations": {
          "jobservice": {
            "Address": "https://localhost:5257/api/job"
          }
        }
      },
      "examservice": {
        "Destinations": {
          "examservice": {
            "Address": "https://localhost:5260/api/exam"
          }
        }
      },
      "notificationservice": {
        "Destinations": {
          "notificationservice": {
            "Address": "https://localhost:5149/api/notification"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
