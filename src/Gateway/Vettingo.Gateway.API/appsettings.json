{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "AnalyticsService": {
        "ClusterId": "analyticsservice",
        "Match": {
          "Path": "/analytics/{**catch-all}"
        }
      },
      "AuthService": {
        "ClusterId": "authservice",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "EvaluationService": {
        "ClusterId": "evaluationservice",
        "Match": {
          "Path": "/evaluation/{**catch-all}"
        }
      },
      "NotificationService": {
        "ClusterId": "notificationservice",
        "Match": {
          "Path": "/notification/{**catch-all}"
        }
      },
      "ExamService": {
        "ClusterId": "examservice",
        "Match": {
          "Path": "/exam/{**catch-all}"
        }
      },
      "JobService": {
        "ClusterId": "jobservice",
        "Match": {
          "Path": "/job/{**catch-all}"
        }
      },
      "InterviewService": {
        "ClusterId": "interviewservice",
        "Match": {
          "Path": "/interview/{**catch-all}"
        }
      }


    },
    "Clusters": {
      "analyticsservice": {
        "Destinations": {
          "analyticsservice": {
            "Address": "https://localhost:5001/api/analytics"
          }
        }
      },
      "authservice": {
        "Destinations": {
          "authservice": {
            "Address": "https://localhost:5002/api/auth"
          }
        }
      },
      "evaluationservice": {
        "Destinations": {
          "evaluationservice": {
            "Address": "https://localhost:5003/api/evaluation"
          }
        }
      },
      "interviewservice": {
        "Destinations": {
          "interviewservice": {
            "Address": "https://localhost:5004/api/interview"
          }
        }
      },
      "jobservice": {
        "Destinations": {
          "jobservice": {
            "Address": "https://localhost:5005/api/job"
          }
        }
      },
      "examservice": {
        "Destinations": {
          "examservice": {
            "Address": "https://localhost:5006/api/exam"
          }
        }
      },
      "notificationservice": {
        "Destinations": {
          "notificationservice": {
            "Address": "https://localhost:5007/api/notification"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
